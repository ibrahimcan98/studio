
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Türk Çocuk Akademisi platform.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "teacher", "admin"] },
        "isPremium": { "type": "boolean" },
        "premiumStartDate": { "type": "string", "format": "date-time" },
        "premiumEndDate": { "type": "string", "format": "date-time" },
        "lives": { "type": "number" },
        "livesLastUpdatedAt": { "type": "string", "format": "date-time" },
        "enrolledPackages": { "type": "array", "items": { "type": "string" } },
        "remainingLessons": { "type": "number" },
        "freeTrialsUsed": { "type": "number" },
        "timezone": { "type": "string" },
        "bio": { "type": "string" },
        "hobbies": { "type": "array", "items": { "type": "string" } },
        "introVideoUrl": { "type": "string", "format": "uri" },
        "googleMeetLink": { "type": "string", "format": "uri" },
        "isProfileComplete": { "type": "boolean" },
        "lastActiveAt": { "type": "string", "format": "date-time", "description": "Last time the user navigated to a page." },
        "currentPath": { "type": "string", "description": "The URL path the user is currently on." }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents a financial transaction/purchase.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "amountEur": { "type": "number" },
        "items": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "priceEur": { "type": "number" }
            }
          }
        },
        "type": { "type": "string", "enum": ["package", "premium"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amountEur", "type", "createdAt"]
    },
    "Child": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Child",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "countryOfResidence": { "type": "string" },
        "level": { "type": "string" },
        "remainingLessons": { "type": "number" },
        "assignedPackage": { "type": "string" },
        "completedTopics": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "firstName"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/users/{userId}/children/{childId}",
        "definition": {
          "entityName": "Child",
          "schema": { "$ref": "#/backend/entities/Child" },
          "description": "Children profiles."
        }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "Financial records for admin monitoring."
        }
      }
    ]
  }
}
