
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Türk Çocuk Akademisi platform.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "teacher", "admin"] },
        "walletBalanceEur": { "type": "number", "description": "Current balance in EUR." },
        "academyPoints": { "type": "number", "description": "Current loyalty points." },
        "totalPackagesPurchased": { "type": "number", "description": "Total number of packages bought." },
        "referralCode": { "type": "string", "description": "Unique referral code for the user." },
        "isPremium": { "type": "boolean" },
        "lives": { "type": "number" },
        "remainingLessons": { "type": "number" },
        "freeTrialsUsed": { "type": "number" },
        "taskStatus": { 
            "type": "object", 
            "description": "Status of missions (e.g., { 'mission-1': 'pending' })." 
        },
        "isProfileComplete": { "type": "boolean" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles with wallet and point tracking."
        }
      }
    ]
  }
}
