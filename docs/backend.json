
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Türk Çocuk Akademisi platform.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "teacher", "admin"] },
        "isPremium": { "type": "boolean" },
        "lives": { "type": "number" },
        "timezone": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Conversation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Conversation",
      "type": "object",
      "description": "Represents a support conversation or lead.",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "pending", "closed"] },
        "channel": { "type": "string", "enum": ["website", "whatsapp"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdBy": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["anonymous", "parent"] },
            "uid": { "type": "string" },
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "topic": { "type": "string" },
        "assignedTeam": { "type": "string", "enum": ["Eğitim", "Teknik/Satış"] },
        "needsHuman": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["status", "channel", "createdAt", "createdBy"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "A single message within a conversation.",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderType": { "type": "string", "enum": ["anonymous", "parent", "admin", "ai"] },
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["conversationId", "senderType", "text", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/conversations/{conversationId}",
        "definition": {
          "entityName": "Conversation",
          "schema": { "$ref": "#/backend/entities/Conversation" },
          "description": "Support conversations."
        }
      },
      {
        "path": "/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Individual chat messages."
        }
      }
    ]
  }
}
