
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow get: if request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.createdBy.uid == request.auth.uid) || true; // Reading is more open for local tracking
      allow create: if true;
      allow update: if isAdmin() || (request.auth != null && resource.data.createdBy.uid == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.senderUid == request.auth.uid) || true;
      allow create: if true;
    }

    // Existing rules for lessons, topics etc...
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
