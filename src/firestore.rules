rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@hotmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isTeacher() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }

    // USER RULES
    match /users/{userId} {
      allow get, create, update, delete: if isSignedIn() && request.auth.uid == userId;
      allow get, list: if isAdmin() || isTeacher();

      match /children/{childId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        allow read: if isAdmin() || isTeacher();
        allow write: if isAdmin();
      }
    }

    // LESSON RULES
    match /lesson-slots/{slotId} {
        allow read: if isSignedIn();
        allow create: if isTeacher() || isAdmin();
        allow update: if (isSignedIn() && resource.data.status == 'available' && request.resource.data.status == 'booked') || 
                       (isSignedIn() && request.auth.uid == resource.data.teacherId) || isAdmin();
        allow delete: if (isSignedIn() && request.auth.uid == resource.data.teacherId) || isAdmin();
    }
    
    // CONVERSATION RULES
    match /conversations/{conversationId} {
      allow create: if true;
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.createdBy.uid == request.auth.uid || 
        request.auth.uid == resource.data.assignedTo
      ));
      allow update: if isAdmin() || (isSignedIn() && resource.data.createdBy.uid == request.auth.uid);
    }

    // MESSAGE RULES - FIXED FOR LISTING
    match /messages/{messageId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.senderUid == request.auth.uid || 
        resource.data.conversationOwnerUid == request.auth.uid
      ));
    }
    
    // OTHER RULES
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}