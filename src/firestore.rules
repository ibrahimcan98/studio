rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // YARDIMCI FONKSİYONLAR
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@hotmail.com' ||
        request.auth.uid == 'HjYBaEgRUsQ4DUIvBlFfrx7ND6p1' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // 1. DESTEK SİSTEMİ - TAMAMEN AÇIK (KULLANICI TALEBİ)
    match /conversations/{id} {
      allow read, write: if true;
    }

    match /messages/{id} {
      allow read, write: if true;
    }

    // 2. KULLANICI VE ÇOCUK VERİLERİ
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Velilerin öğretmen profillerini görebilmesi için
      allow get: if isSignedIn() && (
        resource.data.role == 'teacher' || 
        get(/databases/$(database)/documents/users/$(userId)).data.role == 'teacher'
      );
      
      // Admin her şeyi görebilir
      allow list, get: if isAdmin();

      match /children/{childId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        allow read: if isAdmin();
      }
    }

    // Collection Group kuralı (Admin için tüm çocukları listeleme yetkisi)
    match /{path=**}/children/{childId} {
      allow read: if isAdmin();
    }

    // 3. DERS SLOTLARI
    match /lesson-slots/{slotId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
        
        match /chats/{chatId} {
          allow read, write: if isSignedIn();
        }
    }
    
    // 4. GENEL VERİLER
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 5. GLOBAL ADMIN ERİŞİMİ
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}