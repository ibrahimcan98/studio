
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
     
    match /users/{userId} {
      // A user can get their own doc.
      // A teacher or admin can get any user's doc.
      // Any authenticated user can get a user doc if that user's role is 'teacher' (for profile viewing).
      allow get: if request.auth.uid == userId 
                  || isTeacher() 
                  || isAdmin() 
                  || (request.auth != null && get(/databases/$(database)/documents/users/$(userId)).data.role == 'teacher');
      
      allow list: if isTeacher() || isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    match /users/{userId}/children/{childId} {
      allow get, list: if request.auth.uid == userId || isTeacher() || isAdmin();
      // A user can create/update their own child, a teacher can update, or an admin can.
      // create/update: The incoming child document's userId must match the parent's uid.
      allow create, update: if (request.auth.uid == userId && request.resource.data.userId == userId) || isTeacher() || isAdmin();
      // delete: The parent must be the one deleting, checking the existing document's userId.
      allow delete: if (request.auth.uid == userId && resource.data.userId == userId) || isAdmin();
    }

    match /lesson-slots/{slotId} {
        allow get, list: if request.auth != null;
        // Teacher can create their own slot. Admin can create any slot.
        allow create: if (isTeacher() && request.auth.uid == request.resource.data.teacherId) || isAdmin();
        // A user can book an available slot.
        // The teacher of the slot can modify it.
        // The user who booked can modify (e.g., cancel) it.
        // An admin can modify it.
        allow update: if (request.auth != null && resource.data.status == 'available' && request.resource.data.status == 'booked') || 
                       (request.auth.uid == resource.data.teacherId) || 
                       (request.auth.uid == resource.data.bookedBy) || isAdmin();
        allow delete: if request.auth.uid == resource.data.teacherId || isAdmin();
    }
    
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/enrollments/{enrollmentId} {
      allow get, list: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId && request.resource.data.userId == userId;
      allow update, delete: if request.auth.uid == userId;
    }

    match /users/{userId}/purchases/{purchaseId} {
        allow get, list: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId;
        allow update, delete: if false;
    }

    match /courses/{courseId}/lessons/{lessonId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.userId || isAdmin();
    }
  }
}

    