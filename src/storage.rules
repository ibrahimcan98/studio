rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read access for all files is allowed.
    match /{allPaths=**} {
      allow read;
    }

    // A teacher can only write (upload, update, delete) to their own profile directory.
    // The {userId} in the path must match the UID of the authenticated user.
    match /teacher-profiles/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
