
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@hotmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isTeacher() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }
     
    match /users/{userId} {
      allow get: if request.auth.uid == userId || isAdmin() || isTeacher();
      allow list: if isAdmin() || isTeacher();
      allow create: if request.auth.uid == userId;
      allow update, delete: if request.auth.uid == userId || isAdmin();
    }

    match /users/{userId}/children/{childId} {
      allow get, list: if request.auth.uid == userId || isAdmin() || isTeacher();
      allow create, update, delete: if request.auth.uid == userId || isAdmin();
    }

    match /lesson-slots/{slotId} {
        allow get, list: if request.auth != null;
        allow create: if isTeacher() || isAdmin();
        allow update: if (isSignedIn() && resource.data.status == 'available' && request.resource.data.status == 'booked') || 
                       (request.auth.uid == resource.data.teacherId) || isAdmin();
        allow delete: if request.auth.uid == resource.data.teacherId || isAdmin();
    }
    
    match /conversations/{conversationId} {
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.createdBy.uid == request.auth.uid || 
        request.auth.uid == resource.data.assignedTo
      ));
      allow create: if true;
      allow update: if isAdmin() || (isSignedIn() && resource.data.createdBy.uid == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.senderUid == request.auth.uid || 
        get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.createdBy.uid == request.auth.uid
      ));
      allow create: if true;
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
