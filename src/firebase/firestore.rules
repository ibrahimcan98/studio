
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // YARDIMCI FONKSİYONLAR
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. KULLANICI VE SAHİPLİK KURALLARI (EN ÜSTTE)
    // Bu kural, kullanıcının kendi dokümanı ve tüm alt koleksiyonları (bildirimler, çocuk verileri vb.) için tam yetki sağlar.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 2. ÖZEL KULLANICI KURALLARI (Kapsam dışı veya ek izinler)
    match /users/{userId} {
      // Adminler tüm kullanıcı verilerini listeleyebilir
      allow get, list: if isAdmin();
      
      // Kayıt sırasında email/kullanıcı kontrolü için kısıtlı okuma
      allow get, list: if isSignedIn();

      match /children/{childId} {
        // Öğretmenler ve Adminler çocuk verilerini görebilir
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher']);
        
        // Öğretmenler gelişim raporlarını güncelleyebilir
        allow update: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      }
    }

    // 3. DERS SLOTLARI
    match /lesson-slots/{slotId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
        
        match /chats/{chatId} {
          allow read, write: if isSignedIn();
        }
    }
    
    // 4. İŞLEMLER VE GENEL VERİLER
    match /transactions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /activity-log/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /notifications-log/{id} {
      allow read, write: if isAdmin();
    }

    // 5. DESTEK SİSTEMİ (Chat vb.)
    match /conversations/{id} {
      allow read, write: if true;
    }

    match /messages/{id} {
      allow read, write: if true;
    }

    // 6. GLOBAL ADMIN ERİŞİMİ
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
