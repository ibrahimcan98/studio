
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Check if user is authenticated before checking for role.
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // This function is for legacy user documents. New admin panel uses 'parents' collection.
    function isLegacyTeacher() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
     
    // Rules for the new data structure
    match /parents/{parentId} {
      allow read, write: if isAdmin();
    }

    match /students/{studentId} {
      allow read, write: if isAdmin();
    }
    
    match /sales/{saleId} {
      allow read, write: if isAdmin();
    }

    match /trials/{trialId} {
      allow read, write: if isAdmin();
    }

    // LEGACY RULES (for existing app structure)
    // It's important to keep them to not break the current app functionality.
    match /users/{userId} {
      allow get: if request.auth.uid == userId || isLegacyTeacher() || isAdmin() || (request.auth != null && get(/databases/$(database)/documents/users/$(userId)).data.role == 'teacher');
      allow list: if isLegacyTeacher() || isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    match /users/{userId}/children/{childId} {
      allow get, list: if request.auth.uid == userId || isLegacyTeacher() || isAdmin();
      allow create, update: if (request.auth.uid == userId && request.resource.data.userId == userId) || isLegacyTeacher() || isAdmin();
      allow delete: if (request.auth.uid == userId && resource.data.userId == userId) || isAdmin();
    }

    match /lesson-slots/{slotId} {
        allow get, list: if request.auth != null;
        allow create: if isLegacyTeacher() || isAdmin();
        allow update: if (request.auth != null && resource.data.status == 'available' && request.resource.data.status == 'booked') || 
                       (request.auth.uid == resource.data.teacherId) || isAdmin();
        allow delete: if request.auth.uid == resource.data.teacherId || isAdmin();
    }

    match /courses/{courseId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/enrollments/{enrollmentId} {
      allow get, list: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId && request.resource.data.userId == userId;
      allow update, delete: if request.auth.uid == userId;
    }

    match /users/{userId}/purchases/{purchaseId} {
        allow get, list: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId;
        allow update, delete: if false;
    }

    match /courses/{courseId}/lessons/{lessonId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.userId || isAdmin();
    }
  }
}
