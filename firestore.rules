
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
     
    match /users/{userId} {
      allow get: if request.auth.uid == userId || isTeacher() || isAdmin();
      allow list: if isTeacher() || isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    match /users/{userId}/children/{childId} {
      allow get, list: if request.auth.uid == userId || isTeacher() || isAdmin();
      // A user can create/update/delete their own child, or an admin can.
      // create: The incoming child document's userId must match the parent's uid.
      // update: The parent must be the one updating, and they can't change the owner.
      // delete: The parent must be the one deleting.
      allow create, update, delete: if (request.auth.uid == userId && request.resource.data.userId == userId) || isAdmin();
    }

    match /lesson-slots/{slotId} {
        allow get, list: if request.auth != null;
        allow create: if isTeacher() || isAdmin();
        allow update: if (request.auth != null && resource.data.status == 'available' && request.resource.data.status == 'booked') || 
                       (request.auth.uid == resource.data.teacherId) || isAdmin();
        allow delete: if request.auth.uid == resource.data.teacherId || isAdmin();
    }
    
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/enrollments/{enrollmentId} {
      allow get, list: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId && request.resource.data.userId == userId;
      allow update, delete: if request.auth.uid == userId;
    }

    match /users/{userId}/purchases/{purchaseId} {
        allow get, list: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId;
        allow update, delete: if false;
    }

    match /courses/{courseId}/lessons/{lessonId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.userId || isAdmin();
    }
  }
}
