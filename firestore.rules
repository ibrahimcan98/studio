
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // YARDIMCI FONKSİYONLAR
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. DESTEK SİSTEMİ
    match /conversations/{id} {
      allow read, write: if true;
    }

    match /messages/{id} {
      allow read, write: if true;
    }

    // 2. KULLANICI VE ÇOCUK VERİLERİ
    match /users/{userId} {
      // Kullanıcı kendi verisini okuyabilir ve yazabilir
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
      
      // Admin her şeyi yapabilir
      allow list, get: if isAdmin();
      
      // Diğer kullanıcıları okuma izni (Referans sorgusu ve öğretmen listesi için)
      allow get, list: if isSignedIn();
      
      // Takip verileri ve Referans Puanları (academyPoints) için dışarıdan güncelleme izni
      allow update: if (isSignedIn() && request.auth.uid == userId) || 
                    (isSignedIn() && resource != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isOnline', 'lastActiveAt', 'currentPath', 'status', 'onlineSince', 'academyPoints']));

      match /children/{childId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher']);
        
        // Öğretmenler gelişim ve geri bildirim verilerini güncelleyebilir
        allow update: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      }
    }

    // 3. DERS SLOTLARI
    match /lesson-slots/{slotId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
        
        match /chats/{chatId} {
          allow read, write: if isSignedIn();
        }
    }
    
    // 4. İŞLEMLER VE GENEL VERİLER
    match /transactions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 5. KUPONLAR VE ÖZEL ERİŞİM
    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /loyalty-requests/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /activity-log/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
