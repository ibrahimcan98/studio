
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // YARDIMCI FONKSİYONLAR
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@hotmail.com' ||
        request.auth.uid == 'HjYBaEgRUsQ4DUIvBlFfrx7ND6p1'
      );
    }

    // 1. DESTEK SİSTEMİ
    match /conversations/{id} {
      allow read, write: if true;
    }

    match /messages/{id} {
      allow read, write: if true;
    }

    // 2. KULLANICI VE ÇOCUK VERİLERİ
    match /users/{userId} {
      // Admin her şeyi yapabilir
      allow read, write: if isAdmin();
      
      // Kullanıcı kendi verisini okuyabilir ve yazabilir
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Takip verileri için özel izin (isOnline vb.)
      allow update: if (isSignedIn() && request.auth.uid == userId) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isOnline', 'lastActiveAt', 'currentPath', 'onlineSince']));

      match /children/{childId} {
        allow read, write: if isAdmin();
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 3. DERS SLOTLARI
    match /lesson-slots/{slotId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
        
        match /chats/{chatId} {
          allow read, write: if isSignedIn();
        }
    }
    
    // 4. İŞLEMLER VE GENEL VERİLER
    match /transactions/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 5. GLOBAL ADMIN ERİŞİMİ
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
