
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow teacher to read user and child data ONLY if they are the teacher for a booked lesson
    function isTeacherForBookedSlot(userId) {
      return exists(/databases/$(database)/documents/lesson-slots) &&
             exists(
                /databases/$(database)/documents/lesson-slots.filter(
                  where('teacherId', '==', request.auth.uid)
                  .where('bookedBy', '==', userId)
                  .where('status', '==', 'booked')
                )
             );
    }
     
    match /users/{userId} {
      allow get: if request.auth.uid == userId || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' && isTeacherForBookedSlot(userId));
      allow read, update, delete: if request.auth.uid == userId;
      allow list: if false; 
      allow create: if request.auth.uid == userId;
    }

    match /users/{userId}/children/{childId} {
      allow get, list: if request.auth.uid == userId || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' && isTeacherForBookedSlot(userId));
      allow read, update, delete: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId && request.resource.data.userId == userId;
    }

    match /lesson-slots/{slotId} {
        allow get, list: if request.auth != null;
        allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
        allow update: if request.auth != null && resource.data.status == 'available' && request.resource.data.status == 'booked';
        allow delete: if request.auth.uid == resource.data.teacherId && resource.data.status == 'available';
    }
    
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; 
      allow update: if false; 
      allow delete: if false; 
    }

    match /users/{userId}/enrollments/{enrollmentId} {
      allow get: if request.auth.uid == userId;
      allow list: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId && request.resource.data.userId == userId;
      allow update: if request.auth.uid == userId && resource != null;
      allow delete: if request.auth.uid == userId && resource != null;
    }

    match /users/{userId}/purchases/{purchaseId} {
        allow get: if request.auth.uid == userId;
        allow list: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId;
        allow update: if false;
        allow delete: if false;
    }

    match /courses/{courseId}/lessons/{lessonId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; 
      allow update: if false; 
      allow delete: if false; 
    }

    match /reviews/{reviewId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth.uid == resource.data.userId && resource != null;
      allow delete: if request.auth.uid == resource.data.userId && resource != null;
    }
  }
}
