
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // YARDIMCI FONKSİYONLAR
    function isSignedIn() {
      return request.auth != null;
    }

    // 1. DESTEK SİSTEMİ - TAMAMEN AÇIK (KULLANICI TALEBİ)
    // Herhangi bir doğrulama gerektirmez, herkes mesaj yazabilir ve okuyabilir.
    match /conversations/{id} {
      allow read, write: if true;
    }

    match /messages/{id} {
      allow read, write: if true;
    }

    // 2. KULLANICI VE ÇOCUK VERİLERİ
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Velilerin öğretmen profillerini görebilmesi için (Ders Planlama Önizlemesi)
      allow get: if isSignedIn() && (
        resource.data.role == 'teacher' || 
        get(/databases/$(database)/documents/users/$(userId)).data.role == 'teacher'
      );
      
      // Admin ve öğretmenler için genel erişim
      allow list, get: if isSignedIn() && (
        request.auth.token.email == 'admin@hotmail.com' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher']
      );

      match /children/{childId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        allow read: if isSignedIn() && (
          request.auth.token.email == 'admin@hotmail.com' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher']
        );
      }
    }

    // 3. DERS SLOTLARI VE HIZLI MESAJLAR
    match /lesson-slots/{slotId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();

        // Hızlı Mesajlar (Ders Bazlı)
        match /chats/{chatId} {
          allow read: if isSignedIn() && (
            resource == null ||
            get(/databases/$(database)/documents/lesson-slots/$(slotId)).data.teacherId == request.auth.uid ||
            get(/databases/$(database)/documents/lesson-slots/$(slotId)).data.bookedBy == request.auth.uid ||
            request.auth.token.email == 'admin@hotmail.com'
          );
          allow create: if isSignedIn() && (
            get(/databases/$(database)/documents/lesson-slots/$(slotId)).data.teacherId == request.auth.uid ||
            get(/databases/$(database)/documents/lesson-slots/$(slotId)).data.bookedBy == request.auth.uid
          );
        }
    }
    
    // 4. GENEL VERİLER
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.email == 'admin@hotmail.com';
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || request.auth.token.email == 'admin@hotmail.com');
    }

    // 5. GLOBAL ADMIN ERİŞİMİ
    match /{document=**} {
      allow read, write: if isSignedIn() && request.auth.token.email == 'admin@hotmail.com';
    }
  }
}
