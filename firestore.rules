
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow teacher to read user and child data ONLY if they are the teacher for a booked lesson
    function isTeacherForBookedSlot(userId) {
      // This function is complex for security rules. A cross-collection query like this isn't supported directly.
      // Instead, we will rely on checking the role and assume the UI only shows valid links.
      // For robust security, this would ideally be handled with custom claims or a separate lookup collection.
      // For this app's purpose, we simplify to allow teachers to read data if they are linked via a booked slot.
      // A truly secure rule would require duplicating data or using claims.
      // This simplified version allows a teacher to read any user if they have a booked slot with *anyone*.
      // A better approach is to check if a specific slot exists linking teacher and parent.
      return exists(
        /databases/$(database)/documents/lesson-slots.where("teacherId", "==", request.auth.uid).where("bookedBy", "==", userId).where("status", "==", "booked")
      );
    }
     
    match /users/{userId} {
      // Allow a user to get their own doc OR
      // allow a teacher to get the doc of a user for whom they have a booked lesson.
      allow get: if request.auth.uid == userId || 
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' && isTeacherForBookedSlot(userId));
      allow list: if false; 
      allow create, update, delete: if request.auth.uid == userId;
    }

    match /users/{userId}/children/{childId} {
      // Allow a user to get their own children OR
      // allow a teacher to get the children of a user for whom they have a booked lesson.
      allow get, list: if request.auth.uid == userId || 
                         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' && isTeacherForBookedSlot(userId));
      allow create, update, delete: if request.auth.uid == userId && request.resource.data.userId == userId;
    }

    match /lesson-slots/{slotId} {
        allow get, list: if request.auth != null;
        allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
        // Allow a user to book an available slot or a teacher to modify their own available slot
        allow update: if (request.auth != null && resource.data.status == 'available' && request.resource.data.status == 'booked') || 
                       (request.auth.uid == resource.data.teacherId);
        allow delete: if request.auth.uid == resource.data.teacherId;
    }
    
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; 
      allow update: if false; 
      allow delete: if false; 
    }

    match /users/{userId}/enrollments/{enrollmentId} {
      allow get: if request.auth.uid == userId;
      allow list: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId && request.resource.data.userId == userId;
      allow update: if request.auth.uid == userId && resource != null;
      allow delete: if request.auth.uid == userId && resource != null;
    }

    match /users/{userId}/purchases/{purchaseId} {
        allow get: if request.auth.uid == userId;
        allow list: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId;
        allow update: if false;
        allow delete: if false;
    }

    match /courses/{courseId}/lessons/{lessonId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; 
      allow update: if false; 
      allow delete: if false; 
    }

    match /reviews/{reviewId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth.uid == resource.data.userId && resource != null;
      allow delete: if request.auth.uid == resource.data.userId && resource != null;
    }
  }
}
